{
    "version": 2,
    "outputDirectory": "public",
    "functions": {
        "api/pay.js": {
            "memory": 128,
            "maxDuration": 30
        },
        "api/status.js": {
            "memory": 128,
            "maxDuration": 30
        },
        "api/result.js": {
            "memory": 128,
            "maxDuration": 30
        }
    },
    "routes": [
        {
            "src": "/api/pay",
            "dest": "/api/pay.js"
        },
        {
            "src": "/api/status",
            "dest": "/api/status.js"
        },
        {
            "src": "/api/result",
            "dest": "/api/result.js"
        },
        {
            "src": "/(.*)",
            "dest": "/index.html"
        }
    ]
}